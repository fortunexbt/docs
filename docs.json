{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Fortune Field Manual",
  "description": "Architecture tours, reproducible demos, and release evidence for systems that show their work.",
  "colors": {
    "primary": "#075985",
    "light": "#48EEFF",
    "dark": "#9C6CFF"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "fonts": {
    "family": "IBM Plex Sans",
    "weight": 400,
    "heading": {
      "family": "IBM Plex Mono",
      "weight": 600
    },
    "body": {
      "family": "IBM Plex Sans",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#F4F7F6",
      "dark": "#09080B"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "vitesse-dark"
      }
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Field manual",
        "icon": "radar",
        "groups": [
          {
            "group": "Start",
            "pages": [
              "index",
              "start-here"
            ]
          },
          {
            "group": "Architecture tours",
            "pages": [
              "architecture/mutx",
              "architecture/tablebeam",
              "architecture/terminal-starfield",
              "architecture/ckitty"
            ]
          },
          {
            "group": "Design principles",
            "pages": [
              "principles/index"
            ]
          }
        ]
      },
      {
        "tab": "Demo recipes",
        "icon": "play",
        "groups": [
          {
            "group": "Reproduce the claim",
            "pages": [
              "recipes/index",
              "recipes/mutx-operator-loop",
              "recipes/tablebeam-source-trail",
              "recipes/starfield-seeded-run",
              "recipes/ckitty-deterministic-frame"
            ]
          }
        ]
      },
      {
        "tab": "Proof & labs",
        "icon": "shield-check",
        "groups": [
          {
            "group": "Proof discipline",
            "pages": [
              "proof/build-and-release"
            ]
          },
          {
            "group": "Labs",
            "pages": [
              "labs/status",
              "labs/barter",
              "labs/securepath"
            ]
          },
          {
            "group": "Night-shift launches",
            "pages": [
              "labs/solar-drift",
              "labs/loop-courier",
              "labs/switchyard"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/fortunexbt",
          "icon": "github"
        },
        {
          "anchor": "MUTX",
          "href": "https://mutx.dev",
          "icon": "activity"
        }
      ]
    }
  },
  "redirects": [
    {
      "source": "/quickstart",
      "destination": "/start-here"
    },
    {
      "source": "/development",
      "destination": "/start-here"
    },
    {
      "source": "/essentials/:slug*",
      "destination": "/principles"
    },
    {
      "source": "/ai-tools/:slug*",
      "destination": "/start-here"
    },
    {
      "source": "/api-reference/:slug*",
      "destination": "/architecture/mutx"
    }
  ],
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/fortunexbt"
      },
      {
        "label": "Portfolio",
        "href": "https://fortunexbt.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Run MUTX",
      "href": "https://mutx.dev"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "thumbnails": {
    "appearance": "dark",
    "background": "/images/field-grid.svg",
    "fonts": {
      "family": "IBM Plex Mono"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/fortunexbt",
      "x": "https://x.com/fortunexbt"
    }
  }
}
